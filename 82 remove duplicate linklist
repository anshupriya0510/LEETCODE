82 remove duplicte linklist
class Solution {
    public ListNode deleteDuplicates(ListNode head) {
    
        ListNode i = head;
        while(i!=null&&i.next !=null){
            if(i.val==i.next.val){
                i.next = i.next.next;
            }
            else{
                i=i.next;
            }
        }
    
        return head;
        
    }
}
